{
  "name": "sheffield-cycle-map",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "fetch:osm": "python3 scripts/fetch_osm.py",
    "fetch:all": "set -e; npm run fetch:osm && node scripts/dft_collisions.js && node scripts/bike_thefts.js",
    "build": "esbuild src/main.js --bundle --format=esm --loader:.css=css --outfile=public/bundle.js --sourcemap --minify",
    "serve": "npm run build && npx serve public --single --listen 4174",
    "georef": "node scripts/georef/adjust.js",
    "style-fix": "prettier --write ."
  },
  "dependencies": {
    "blurhash": "^2.0.5",
    "csv-parse": "^6.1.0",
    "maplibre-gl": "^5.14.0",
    "opening_hours": "^3.9.0",
    "proj4": "^2.20.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "esbuild": "^0.27.1",
    "prettier": "^3.7.4",
    "serve": "^14.2.5"
  }
}
